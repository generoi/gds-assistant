{
  "name": "gds-assistant",
  "private": true,
  "scripts": {
    "build": "wp-scripts build",
    "build:production": "wp-scripts build",
    "start": "wp-scripts start",
    "test": "npm run lint",
    "lint": "npm run lint:prettier && npm run lint:js",
    "lint:js": "wp-scripts lint-js resources",
    "lint:prettier": "prettier --check .",
    "lint:fix": "npm run lint:fix:prettier && npm run lint:fix:js",
    "lint:fix:prettier": "prettier --write .",
    "lint:fix:js": "wp-scripts lint-js resources --fix",
    "ci:scripts": "wp-scripts lint-js resources/scripts --format checkstyle",
    "translate": "npm run translate:pot && npm run translate:js",
    "translate:pot": "npm run wp -- i18n make-pot . ./resources/lang/gds-assistant.pot --domain=gds-assistant --include=\"src,resources\"",
    "translate:js": "npm run wp -- i18n make-json ./resources/lang --pretty-print",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js",
    "wp": "../../../../vendor/bin/wp"
  },
  "eslintConfig": {},
  "dependencies": {
    "@assistant-ui/react": "^0.12.0",
    "@assistant-ui/react-markdown": "^0.12.0",
    "@assistant-ui/react-streamdown": "^0.1.9",
    "@wordpress/api-fetch": "^7.43.0",
    "@wordpress/components": "^32.5.0",
    "@wordpress/core-data": "^7.43.0",
    "@wordpress/data": "^10.43.0",
    "@wordpress/dataviews": "^14.0.0",
    "@wordpress/dom-ready": "^4.43.0",
    "@wordpress/i18n": "^6.16.0",
    "@wordpress/icons": "^12.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@wordpress/e2e-test-utils-playwright": "^1.43.0",
    "@wordpress/scripts": "~31.6.0",
    "postcss-prefix-selector": "^2.1.1",
    "tailwindcss": "^4.0.0"
  }
}
