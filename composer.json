{
  "name": "generoi/gds-assistant",
  "type": "wordpress-plugin",
  "license": "MIT",
  "description": "AI-powered admin assistant with WordPress tool access",
  "homepage": "https://github.com/generoi/gds-assistant",
  "authors": [
    {
      "name": "Genero",
      "email": "info@genero.fi"
    }
  ],
  "require": {
    "php": ">=8.3.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "phpunit/phpunit": "^9.0",
    "wp-phpunit/wp-phpunit": "^6.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "GeneroWP\\Assistant\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GeneroWP\\Assistant\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "pint --test",
    "lint:fix": "pint",
    "test": "phpunit",
    "test:wp-env": "wp-env run tests-cli --env-cwd=wp-content/plugins/gds-assistant vendor/bin/phpunit"
  }
}
